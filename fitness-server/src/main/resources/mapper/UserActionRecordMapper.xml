<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fitness.mapper.UserActionRecordMapper">
    <resultMap id="BaseResultMap" type="com.fitness.entity.UserActionRecord">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="action_id" property="actionId"/>
        <result column="record_date" property="recordDate"/>
        <result column="weight_kg" property="weightKg"/>
        <result column="max_reps" property="maxReps"/>
        <result column="note" property="note"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>
    <select id="selectByUserIdAndAction" resultMap="BaseResultMap">
        SELECT * FROM user_action_record
        WHERE user_id = #{userId} AND action_id = #{actionId}
        ORDER BY record_date DESC
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO user_action_record (user_id, action_id, record_date, weight_kg, max_reps, note)
        VALUES (#{userId}, #{actionId}, #{recordDate}, #{weightKg}, #{maxReps}, #{note})
    </insert>
    <select id="selectByUserIdAndActionId" resultMap="BaseResultMap">
        SELECT * FROM user_action_record
        WHERE user_id = #{userId} AND action_id = #{actionId}
        ORDER BY record_date DESC
    </select>
</mapper>
